# Database
POSTGRES_USER=smartmoney
POSTGRES_PASSWORD=changeme
POSTGRES_DB=smartmoney
POSTGRES_URL=postgresql://smartmoney:changeme@postgres:5432/smartmoney

# Redis
REDIS_URL=redis://redis:6379/0

# Alerts
ALERTS_ENABLED=false
NOTIFY_DRY_RUN=false
ALERT_INSTANT_ENABLED=false
DASHBOARD_PUBLIC_URL=http://192.168.1.42:3000
WHATSAPP_TO=91XXXXXXXXXX
WHATSAPP_GROUP_ID=
DAILY_PICKS_ENABLED=true
ALERT_MIN_PROBABILITY=0.62
ALERT_MIN_EXPECTED_RETURN_PCT=0.06
ALERT_MIN_DEAL_VALUE_INR=10000000
NTFY_TOPIC=trade-bot-alerts
NTFY_SERVER=http://ntfy:80

# WAHA
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=generate-a-long-random-key
WAHA_SESSION=default
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=changeme

# SEC
SEC_IDENTITY=Your Name your@email.com

# API auth
API_USERNAME=admin
API_PASSWORD=changeme
INTERNAL_API_KEY=host-fallback-key

# Scoring
WIN_THRESHOLD_PCT=0.0
WIN_WINDOW=3mo
TZ=Asia/Kolkata

# Macro / world-demand theme picks
MACRO_THEMES_ENABLED=true
MACRO_THEMES_MAX_SIGNALS=30
MACRO_THEMES_MIN_COMPOSITE=0.12
MACRO_THEMES_WHATSAPP_MAX=3
MACRO_THEMES_MIN_PROBABILITY=0.52
